{
  "name": "vue-dev-inspector",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:demo": "pnpm -C packages/demo dev",
    "build:core": "pnpm -C packages/utils build && pnpm -C packages/shared build && pnpm -C packages/overlay build && pnpm -C packages/client build && pnpm -C packages/core build",
    "build:antd": "pnpm -C packages/antdv build",
    "lint": "eslint \"packages/**/*.{ts,tsx,vue}\"",
    "lint:fix": "eslint \"packages/**/*.{ts,tsx,vue}\" --fix",
    "prettier": "prettier --write \"packages/**/*.{ts,tsx,vue,css,scss,md,json}\"",
    "prepare": "husky install"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-core": "^3.5.38",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/compiler-sfc": "^3.5.38",
    "magic-string": "^0.30.21",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "22.19.17",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tailwindcss": "4.1.17",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx,vue}": "eslint --fix"
  }
}