{
  "name": "@vue-dev-inspector/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",

  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],

  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-sfc  --external @vue-dev-inspector/client"
  },

  "dependencies": {
    "@vue-dev-inspector/overlay": "workspace:*",
    "@vue-dev-inspector/client": "workspace:*",
    "@vue/compiler-sfc": "^3.5.38"
  }
}