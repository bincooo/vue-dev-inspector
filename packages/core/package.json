{
  "name": "@vdi/core",
  "version": "0.0.3",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-sfc && cp ../overlay/dist/overlay.iife.js dist/overlay.iife.js"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.38"
  },
  "devDependencies": {
    "@vdi/shared": "^0.0.1"
  }
}
