{
  "name": "@vue-dev-inspector/core",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/plugin-entry.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-sfc && cp ../overlay/dist/overlay.iife.js dist/overlay.iife.js"
  },
  "dependencies": {
    "@vue/compiler-sfc": "^3.5.38"
  },
  "devDependencies": {
    "@vue-dev-inspector/shared": "workspace:*",
    "@vue-dev-inspector/utils": "workspace:*"
  }
}
