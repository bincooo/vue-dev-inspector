{
  "name": "@vue-dev-inspector/pluginkit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "core 与 uni 共享的插件公共逻辑（AST transform / 配置序列化 / overlay 脚本加载）。node 平台专用。",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-core --external @vue/compiler-sfc --external magic-string --external @vue-dev-inspector/shared --external @vue-dev-inspector/utils",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vue-dev-inspector/shared": "workspace:*",
    "@vue-dev-inspector/utils": "workspace:*",
    "@vue/compiler-core": "^3.5.38",
    "@vue/compiler-sfc": "^3.5.38",
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "5.9.3",
    "tsup": "^8.5.1"
  }
}
