{
  "name": "@vue-dev-inspector/antdv",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./expand": "./dist/expand.iife.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:plugin && pnpm run build:expand",
    "build:plugin": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean",
    "build:expand": "vite build"
  },
  "dependencies": {
    "@vue-dev-inspector/shared": "workspace:*",
    "@vue-dev-inspector/utils": "workspace:*"
  },
  "devDependencies": {
    "vite": "^7.3.2"
  }
}
