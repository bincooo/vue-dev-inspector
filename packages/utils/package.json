{
    "name": "@vue-dev-inspector/utils",
    "version": "0.1.0",
    "private": false,
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean"
    },
    "devDependencies": {
        "@types/node": "^26.0.1",
        "vitest": "^2.1.0"
    }
}