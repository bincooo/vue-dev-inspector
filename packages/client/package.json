{
  "name": "@vdi/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AST-based element props editor + dev server middleware for @vdi/core",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-sfc"
  },
  "dependencies": {
    "@vdi/shared": "^0.0.1"
  }
}
