{
  "name": "@vue-dev-inspector/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AST-based element props editor + dev server middleware for @vue-dev-inspector/core",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --dts --sourcemap --clean --external @vue/compiler-sfc --external @vue/compiler-core",
    "test": "vitest run"
  },
  "dependencies": {
    "@vue-dev-inspector/shared": "workspace:*",
    "@vue/compiler-core": "^3.5.38",
    "@vue/shared": "^3.5.38"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
